// -----------------3.by using function contructor-----------------------
//function constructor - Used to create multiple similar objects.
// Uses this to set properties and optionally prototype methods.

function Person(name, age) {
  this.name = name; // properties
  this.age = age;
}
// const p1 = new Person();
const p1 = new Person("kiran", 20);
p1.name = "kiran";
p1.age = 25;

console.log(p1);

//-------------------3-a adding methods --------
//  function constructor + prototype-------

/*

🔹 Adding Methods

If you add methods directly inside the constructor, each object gets its own copy → wastes memory.

✅ Correct way: put methods on the prototype so they’re shared.
*/

function Person(name) {
  this.name = name;
}

Person.prototype.sayHi = function () {
  console.log("Hi, I'm " + this.name);
};

const user1 = new Person("Kiran");

user1.sayHi();

/*

✅ Characteristics:
-name lives inside the object.
-sayHi lives on Person.prototype (shared among all instances).
-When you console.log(user), you see only { name: "Kiran" } (methods don’t appear inside the object, but they’re available via prototype chain).
Efficient for many objects → all share the same single method in memory.
*/

// -------- create object itself with property and function (constructor returning object(factory style))

function Car(name) {
  return {
    name: name,
    sayHi: function () {
      console.log("hi,I am " + this.name);
    },
  };
}
const user2 = Car("BMW");
console.log(user2);

// no need new keyward becuase it is return a object itself
/*

✅ Characteristics:
-Both name and sayHi exist directly on the object.
-No prototype involvement → every object has its own copy of sayHi.
-Clearer object structure when you inspect in console.
-Less memory efficient if you create many objects (since each one has a     separate copy of the function).
*/

/*

🔹 Conclusion

=> Use constructor + prototype (or ES6 class) when:
-You will create many objects.
-You care about memory efficiency.
-You want to use inheritance / OOP patterns.

=>Use factory style (return object) when:
-You want the object to visibly contain everything ({name, method}).
-You don’t need inheritance.
-You are building small/simple modules or one-off objects.
*/
